{
  "name": "permalink-generator-cypress",
  "version": "1.0.0",
  "private": true,
  "description": "Cypress integration tests for the permalink-generator Jahia module",
  "scripts": {
    "e2e:ci": "cypress run",
    "e2e:debug": "cypress open",
    "lint": "eslint . -c .eslintrc.json --ext .ts",
    "lint:fix": "yarn lint --fix",
    "report:merge": "mochawesome-merge results/reports/cypress*.json > results/reports/report.json && rm results/reports/cypress*.json",
    "report:html": "marge --inline results/reports/report.json --reportDir results/reports/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jahia/permalink-generator.git",
    "directory": "tests"
  },
  "license": "MIT",
  "packageManager": "yarn@1.22.22",
  "devDependencies": {
    "@jahia/cypress": "^7.0.0",
    "@jahia/eslint-config": "^2.1.2",
    "@typescript-eslint/eslint-plugin": "^5.2.0",
    "@typescript-eslint/parser": "^5.2.0",
    "compare-versions": "^6.1.1",
    "cypress": "13.17.0",
    "cypress-multi-reporters": "^1.6.3",
    "cypress-terminal-report": "^5.3.7",
    "cypress-wait-until": "^3.0.1",
    "eslint": "^8.51.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-chai-friendly": "^0.7.2",
    "eslint-plugin-cypress": "^2.15.1",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-promise": "^6.0.0",
    "jahia-reporter": "^0.4.2",
    "mocha": "^10.0.0",
    "mocha-junit-reporter": "^2.2.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^4.2.0",
    "mochawesome-report-generator": "^6.3.2",
    "prettier": "^2.0.0",
    "typescript": "^4.4.4"
  },
  "dependencies": {
    "cross-fetch": "3.1.6"
  },
  "resolutions": {
    "axios": "^1.16.0",
    "qs": "^6.15.2",
    "serialize-javascript": "^7.0.5",
    "uuid": "^11.1.1"
  }
}
