<?xml version="1.0" encoding="UTF-8"?>
<flow xmlns="http://www.springframework.org/schema/webflow"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="
        http://www.springframework.org/schema/webflow
        http://www.springframework.org/schema/webflow/spring-webflow-2.0.xsd">

    <view-state id="settings">
        <on-render>
            <evaluate expression="flowRequestContext.externalContext.nativeRequest.getAttribute('renderContext').site"
                      result="requestScope.site"/>
        </on-render>
        <transition on="cancel" to="settings" bind="false" validate="false"/>
    </view-state>

</flow>
